  "collaboration_rules": {
    "conflict_resolution": {
      "strategy": "timestamp_priority",
      "fallback": "user_arbitration",
      "rules": [
        "时间戳优先：先获取锁的AI获得优先权",
        "优先级次之：同时间时按priority数值决定",
        "用户仲裁：无法解决时标记需要人工介入"
      ]
    },
    "communication_format": {
      "file_modification": {
        "required_fields": ["ai_id", "timestamp", "action", "file_path", "description"],
        "format": {
          "ai_working": "# AI_WORKING: {ai_id} @{timestamp} - {description}",
          "ai_done": "# AI_DONE: {ai_id} @{timestamp}",
          "ai_conflict": "# AI_CONFLICT: {ai_id} @{timestamp} - {issue_description}"
        }
      },
      "state_notifications": {
        "lock_acquired": {
          "type": "notification",
          "message": {
            "event": "lock_acquired",
            "ai_id": "{ai_id}",
            "file": "{file_path}",
            "timestamp": "{timestamp}",
            "expires_at": "{expires_at}"
          }
        },
        "work_completed": {
          "type": "notification", 
          "message": {
            "event": "work_completed",
            "ai_id": "{ai_id}",
            "file": "{file_path}",
            "timestamp": "{timestamp}",
            "changes": "{changes_summary}"
          }
        }
      }
    },
    "atomic_operations": {
      "max_changes_per_file": 3,
      "min_interval_same_file": 5,
      "complex_task_decomposition": true,
      "require_confirmation_after": 5
    }
  },
  "active_plugins": {
    "registration_required": true,
    "auto_cleanup": true,
    "timeout_threshold": 600
  },
  "monitoring": {
    "enabled": true,
    "log_level": "INFO",
    "metrics_collection": true,
    "performance_tracking": true
  }
}