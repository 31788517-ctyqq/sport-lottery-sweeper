# =============================================================================
# 统一环境变量配置示例文件
# =============================================================================

# 注意：此为示例文件，请复制为 .env 并根据需要修改配置
# 不要在此示例文件中填入真实值

# =============================================================================
# PROJECT 配置
# =============================================================================
APP_NAME=竞彩足球扫盘系统
APP_VERSION=1.0.0
DESCRIPTION=Sport Lottery Sweeper System API
PROJECT_NAME=竞彩足球扫盘系统
PROJECT_NAME_CN=竞彩足球扫盘系统
VERSION=0.1.0

# =============================================================================
# API 配置
# =============================================================================
API_URL=http://localhost:8000
API_V1_PREFIX=/api/v1
API_V1_STR=/api/v1
# 前端API基础URL
VITE_API_BASE_URL=http://localhost:8000
VITE_API_URL=http://localhost:8000

# =============================================================================
# SERVER 配置
# =============================================================================
HOST=0.0.0.0
PORT=8000
VITE_DEV_SERVER_HOST=0.0.0.0
VITE_DEV_SERVER_PORT=3000

# =============================================================================
# DEBUG 配置
# =============================================================================
# 调试模式，生产环境设为false
DEBUG=true
# 环境类型: development, staging, production
ENVIRONMENT=development
NODE_ENV=development
VITE_APP_DEBUG=true
VITE_APP_MODE=development

# =============================================================================
# SECURITY 配置
# =============================================================================
# JWT密钥 - 请使用至少32位的随机字符串
SECRET_KEY=your-very-long-and-secure-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
PASSWORD_HASH_ALGORITHM=bcrypt

# =============================================================================
# DATABASE 配置
# =============================================================================
# SQLite配置（开发环境）
DATABASE_URL=sqlite:///./sport_lottery.db
ASYNC_DATABASE_URL=sqlite+aiosqlite:///./sport_lottery.db
# PostgreSQL配置（生产环境）
# DATABASE_URL=postgresql://user:password@localhost:5432/soccer_db
# ASYNC_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/soccer_db

DB_HOST=localhost
DB_PORT=5432
DB_NAME=soccer_db
DB_USER=soccer_user
DB_PASSWORD=soccer_pass

# =============================================================================
# REDIS 配置
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================================================
# CRAWLER 配置
# =============================================================================
CRAWLER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/119.0.0.0 Safari/537.36
CRAWLER_REQUEST_DELAY=2.0

# =============================================================================
# EMAIL 配置
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAILS_FROM_EMAIL=your-email@gmail.com
EMAILS_FROM_NAME=Soccer Scanning System

# =============================================================================
# API Keys (示例，使用时替换为真实值)
# =============================================================================
JC_OFFICIAL_API_KEY=your-jc-api-key-here
JC_OFFICIAL_API_SECRET=your-jc-api-secret-here
BOOKMAKER_API_KEY=your-bookmaker-api-key-here
BOOKMAKER_API_SECRET=your-bookmaker-api-secret-here
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
WEATHER_API_KEY=your-weather-api-key-here

# 数据库配置
DATABASE_URL=sqlite:///./sport_lottery.db
ASYNC_DATABASE_URL=sqlite+aiosqlite:///./sport_lottery.db

# 密钥配置
SECRET_KEY=your-secret-key-here

# API密钥配置
OPENAI_API_KEY=your-openai-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
QWEN_API_KEY=sk-cc3a64c71b9b4696990d2d731b8c7b39

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379

# 日志配置
LOG_LEVEL=INFO

# JWT配置
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# 体育彩票扫盘系统 - 环境配置示例文件
# 请复制此文件为 .env 并根据需要修改配置

# 应用基本配置
APP_NAME=Sport Lottery Sweeper
APP_VERSION=1.0.0
APP_ENV=development           # development, testing, production
APP_DEBUG=true               # 是否开启调试模式
APP_TIMEZONE=Asia/Shanghai   # 时区设置
APP_LOCALE=zh_CN             # 本地化设置

# 服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=1             # 生产环境中可以增加工作进程数

# 数据库配置
# 开发环境使用 SQLite，生产环境使用 PostgreSQL
DB_TYPE=sqlite              # sqlite, postgresql, mysql
DB_NAME=sport_lottery.db    # SQLite 数据库文件路径
# DB_HOST=localhost         # PostgreSQL/MySQL 主机地址
# DB_PORT=5432              # PostgreSQL 默认端口，MySQL 默认 3306
# DB_USER=sport_lottery     # 数据库用户名
# DB_PASSWORD=              # 数据库密码
# DATABASE_URL=postgresql://sport_lottery:password@localhost/sport_lottery  # 完整连接字符串

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# API 配置
# OpenAI 配置
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo

# Gemini 配置
GEMINI_API_KEY=
GEMINI_MODEL=gemini-pro

# Qwen 配置
QWEN_API_KEY=
QWEN_MODEL=qwen-max

# 代理配置（如果需要）
HTTP_PROXY=
HTTPS_PROXY=

# JWT 认证配置
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production  # 生产环境务必更换
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# 爬虫配置
SCRAPER_TIMEOUT=30          # 爬虫请求超时时间（秒）
SCRAPER_DELAY=1             # 爬虫请求间隔（秒）
MAX_CONCURRENT_SCRAPERS=5   # 最大并发爬虫数量

# 日志配置
LOG_LEVEL=INFO              # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=logs/app.log       # 日志文件路径
LOG_MAX_SIZE=10MB           # 单个日志文件最大大小
LOG_BACKUP_COUNT=5          # 保留日志文件数量

# 安全配置
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080  # 允许的跨域请求源
MAX_LOGIN_ATTEMPTS=5        # 最大登录尝试次数
LOGIN_LOCKOUT_DURATION=300  # 登录锁定持续时间（秒）

# 任务调度配置
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
TASK_INTERVAL=60            # 任务执行间隔（秒）

# IP池配置
USE_IP_POOL=false           # 是否使用IP池
IP_POOL_API_URL=           # IP池API地址
MIN_IP_COUNT=5             # 最小IP数量
MAX_IP_COUNT=20            # 最大IP数量

# 系统监控配置
MONITORING_ENABLED=true     # 是否启用监控
HEALTH_CHECK_INTERVAL=30    # 健康检查间隔（秒）

# 文件上传配置
UPLOAD_DIR=uploads          # 上传文件目录
MAX_UPLOAD_SIZE=10MB        # 最大上传文件大小
ALLOWED_EXTENSIONS=csv,xlsx,json,txt  # 允许的文件扩展名

# 邮件配置（如果需要）
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@sport-lottery-sweeper.com
