# =============================================================================
# 体育彩票扫盘系统 - 生产环境配置
# =============================================================================

# 环境标识
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# 数据库配置
DATABASE_URL=postgresql://sport_user:${DB_PASSWORD}@postgres:5432/sport_lottery_prod
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30
DATABASE_POOL_TIMEOUT=30
DATABASE_ECHO_LOG=false

# Redis配置
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=${REDIS_PASSWORD}
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5

# JWT配置
SECRET_KEY=${JWT_SECRET_KEY}
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# 安全配置
CORS_ORIGINS=https://sport-lottery-sweeper.com,https://www.sport-lottery-sweeper.com
CORS_CREDENTIALS=true
ALLOWED_HOSTS=sport-lottery-sweeper.com,www.sport-lottery-sweeper.com
SECURE_HEADERS=true

# API配置
API_V1_STR=/api/v1
MAX_CONTENT_LENGTH=16777216
UPLOAD_FOLDER=/app/uploads
MAX_FILE_SIZE=10485760

# 爬虫配置
CRAWLER_CONCURRENT_REQUESTS=5
CRAWLER_DOWNLOAD_DELAY=1.0
CRAWLER_RESPECT_ROBOTS_TXT=true
CRAWLER_AUTO_THROTTLE_ENABLED=true
CRAWLER_AUTO_THROTTLE_START_DELAY=5.0
CRAWLER_AUTO_THROTTLE_MAX_DELAY=60.0

# 缓存配置
CACHE_TYPE=redis
CACHE_REDIS_URL=redis://redis:6379/1
CACHE_DEFAULT_TIMEOUT=300
CACHE_KEY_PREFIX=sport_lottery_

# 监控配置
ENABLE_METRICS=true
METRICS_ENDPOINT=/metrics
HEALTH_CHECK_INTERVAL=30
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus_multiproc

# 日志配置
LOG_FORMAT=json
LOG_FILE=/app/logs/app.log
LOG_MAX_BYTES=104857600
LOG_BACKUP_COUNT=10
LOG_ROTATION_TIME=midnight

# 邮件配置
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=${SMTP_USERNAME}
SMTP_PASSWORD=${SMTP_PASSWORD}
SMTP_USE_TLS=true
EMAIL_FROM=noreply@sport-lottery-sweeper.com

# 文件上传配置
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx
MAX_IMAGE_SIZE=5242880
MAX_DOCUMENT_SIZE=10485760

# CDN配置
CDN_BASE_URL=https://cdn.sport-lottery-sweeper.com
CDN_ENABLED=true
STATIC_FILE_MAX_AGE=31536000

# 第三方API配置
SPORT_DATA_API_KEY=${SPORT_DATA_API_KEY}
SPORT_DATA_API_BASE_URL=https://api.sportsdata.io/v3/nba
WECHAT_APP_ID=${WECHAT_APP_ID}
WECHAT_APP_SECRET=${WECHAT_APP_SECRET}

# 性能配置
WORKER_PROCESSES=4
WORKER_CONNECTIONS=1000
KEEPALIVE_TIMEOUT=5
CLIENT_MAX_BODY_SIZE=10M

# SSL配置
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem
SSL_PROTOCOLS=TLSv1.2 TLSv1.3
SSL_CIPHERS=ECDHE-RSA-AES128-GCM-SHA256:ECDHE-RSA-AES256-GCM-SHA384
SSL_PREFER_SERVER_CIPHERS=on

# 备份配置
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=/app/backups
BACKUP_DATABASE=true
BACKUP_UPLOADS=true
BACKUP_CONFIG=true