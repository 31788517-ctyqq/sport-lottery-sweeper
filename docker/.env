# =============================================================================
# Docker 环境配置
# =============================================================================
# 此文件用于 Docker Compose 环境

# 容器服务配置
COMPOSE_PROJECT_NAME=sport-lottery-sweeper

# 网络配置
BACKEND_HOST=backend
BACKEND_PORT=8000
FRONTEND_HOST=frontend
FRONTEND_PORT=3000

# 数据库配置 (Docker内部网络)
DATABASE_URL=sqlite:///app/sport_lottery.db
ASYNC_DATABASE_URL=sqlite+aiosqlite:///app/sport_lottery.db

# Redis配置 (Docker内部网络)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# 与外部系统的通信
EXTERNAL_API_BASE_URL=http://host.docker.internal:8000

# 开发环境覆盖 (可选)
# 如需使用宿主机数据库，取消注释以下行：
# DATABASE_URL=sqlite:////app/data/sport_lottery.db
# REDIS_HOST=host.docker.internal