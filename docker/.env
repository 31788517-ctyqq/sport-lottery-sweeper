# 数据库配置
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/soccer_scanner
ASYNC_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/soccer_scanner

# 认证配置
SECRET_KEY=your-super-secret-and-secure-key-change-it-for-production

# API配置
API_V1_PREFIX=/api/v1
DEBUG=true

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 日志配置
LOG_LEVEL=INFO
LOG_FILE_PATH=

# 其他外部服务API
WEATHER_API_KEY=
PROXY_POOL_URL=

# 安全头
ALLOWED_ORIGINS=["*"]

# Scrapy设置
SCRAPY_DATA_DIR=./scrapy_data

# 数据库回显
DATABASE_ECHO=false