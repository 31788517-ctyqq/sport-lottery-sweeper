FROM python:3.11-alpine

WORKDIR /app

# 安装系统依赖
RUN apk update && \
    apk add --no-cache \
        gcc \
        musl-dev \
        linux-headers \
    && rm -rf /var/cache/apk/*

# 复制依赖文件
COPY requirements.txt .

# 安装 Python 依赖
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

# 复制应用代码
COPY . .

# 暴露端口
EXPOSE 8000

# 启动命令
CMD ["python", "main.py"]