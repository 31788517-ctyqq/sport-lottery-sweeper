# =============================================================================
# 数据库配置 - 连接池设置
# =============================================================================
# SQLite配置 (默认)
DATABASE_URL=sqlite:///./sport_lottery.db

# PostgreSQL配置示例 (取消注释并修改)
# DATABASE_URL=postgresql://username:password@localhost:5432/sport_lottery?pool_size=5&max_overflow=10&pool_timeout=30&pool_recycle=3600&pool_pre_ping=true

# MySQL配置示例 (取消注释并修改)  
# DATABASE_URL=mysql+pymysql://username:password@localhost:3306/sport_lottery?charset=utf8mb4&pool_size=5&max_overflow=10&pool_timeout=30&pool_recycle=3600&pool_pre_ping=true

# 数据库连接池设置 (仅对PostgreSQL/MySQL有效)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=true

# =============================================================================
# 异步数据库配置
# =============================================================================
ASYNC_DATABASE_URL=sqlite+aiosqlite:///./sport_lottery.db
# ASYNC_DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/sport_lottery

ASYNC_DB_POOL_SIZE=5
ASYNC_DB_MAX_OVERFLOW=10
ASYNC_DB_POOL_TIMEOUT=30
ASYNC_DB_POOL_RECYCLE=3600

# =============================================================================
# Redis配置
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10
REDIS_MAX_CONNECTIONS=20

# =============================================================================
# API配置
# =============================================================================
API_V1_STR=/api/v1
PROJECT_NAME=竞彩足球扫盘系统
PROJECT_NAME_CN=竞彩足球扫盘系统
VERSION=0.1.0
DESCRIPTION=Sport Lottery Sweeper System API
DEBUG=true
DOCS_ENABLED=true
HOST=0.0.0.0
PORT=8000

# =============================================================================
# 安全配置
# =============================================================================
SECRET_KEY=your-secret-key-change-in-production-2026

# =============================================================================
# 跨域配置
# =============================================================================
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:8080"]

# =============================================================================
# 爬虫配置
# =============================================================================
SCRAPE_INTERVAL=1800
MAX_RETRY=3

# =============================================================================
# 反爬虫配置
# =============================================================================
# 代理设置
PROXY_POOL_ENABLED=true
PROXY_URLS=http://proxy1.example.com:8080,http://proxy2.example.com:8080,socks5://proxy3.example.com:1080
PROXY_HEALTH_CHECK_INTERVAL=300
PROXY_BAN_DURATION=1800
PROXY_MIN_SCORE=20.0

# Cookie设置
COOKIE_FILE=./cookies.json
COOKIE_ENABLED=true

# 请求头设置
HEADER_PROFILE=chrome_desktop
ENABLE_FINGERPRINT=true
HEADER_ROTATION_INTERVAL=50

# 浏览器指纹设置
ENABLE_CANVAS_FINGERPRINT=true
ENABLE_WEBGL_FINGERPRINT=true
SCREEN_RESOLUTIONS=1920x1080,1366x768,1440x900,1536x864,2560x1440
TIMEZONES=Asia/Shanghai,Asia/Beijing,UTC+8,GMT+0800

# =============================================================================
# 日志配置 - 轮转策略
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE_MAX_BYTES=10485760          # 单个日志文件最大字节数 (默认10MB)
LOG_BACKUP_COUNT=30                   # 保留的备份文件数量 (默认30个)
LOG_ROTATION_INTERVAL=midnight       # 轮转间隔: S(秒), M(分), H(小时), D(天), midnight(午夜), W0-W6(周)
LOG_ENCODING=utf-8                   # 日志文件编码
LOG_CLEANUP_ENABLED=true              # 启用自动清理旧日志
LOG_ERROR_BACKUP_MULTIPLIER=2         # 错误日志备份倍数 (保留更久)
LOG_ACCESS_ROTATION=H                 # 访问日志轮转间隔 (默认每小时)
LOG_ACCESS_BACKUP_COUNT=168           # 访问日志保留数量 (默认一周)
DATABASE_ECHO=false

# =============================================================================
# 完整API模式配置
# =============================================================================
FULL_API_MODE=true