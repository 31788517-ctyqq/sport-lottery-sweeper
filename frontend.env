VITE_APP_TITLE=竞彩足球扫盘系统
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=专业的竞彩足球数据分析平台
VITE_APP_KEYWORDS=足球,竞彩,数据分析,扫盘

NODE_ENV=development
VITE_APP_MODE=development
VITE_APP_DEBUG=true

VITE_API_BASE_URL=http://localhost:8000
VITE_API_TIMEOUT=30000
VITE_API_RETRY_ATTEMPTS=3

VITE_FEATURE_AUTH=true
VITE_FEATURE_NOTIFICATIONS=true
VITE_FEATURE_ANALYTICS=true
VITE_FEATURE_PWA=true

VITE_ROUTER_MODE=history
VITE_ROUTER_BASE=/

VITE_CACHE_ENABLED=true
VITE_CACHE_STORAGE=localStorage
VITE_CACHE_TTL=3600

VITE_WS_ENABLED=true
VITE_WS_URL=ws://localhost:8000/ws
VITE_WS_RECONNECT_INTERVAL=5000

VITE_SENTRY_DSN=https://your-sentry-dsn-here
VITE_GOOGLE_ANALYTICS_ID=GA-XXXXXXXXXX
VITE_ADSENSE_ID=ca-pub-XXXXXXXXXXXXXXXX

VITE_CDN_URL=https://cdn.example.com
VITE_CDN_ENABLED=false

VITE_LOG_LEVEL=debug
VITE_LOG_ENABLED=true

VITE_THEME_DEFAULT=light
VITE_THEME_AUTO_SWITCH=true
VITE_THEME_STORAGE_KEY=theme-preference

VITE_I18N_DEFAULT_LOCALE=zh-CN
VITE_I18N_FALLBACK_LOCALE=en

VITE_PERFORMANCE_MONITORING=true
VITE_WEB_VITALS_ENABLED=true

VITE_CSP_ENABLED=true
VITE_X_FRAME_OPTIONS=DENY

VITE_DEV_SERVER_PORT=3000
VITE_DEV_SERVER_HOST=0.0.0.0
VITE_SOURCEMAP_ENABLED=true

VITE_BUILD_OUTDIR=dist
VITE_BUILD_ASSETS_DIR=assets
VITE_BUILD_SOURCEMAP=false

VITE_PWA_NAME=竞彩足球扫盘系统
VITE_PWA_SHORT_NAME=足球扫盘
VITE_PWA_THEME_COLOR=#4DBA87
VITE_PWA_BACKGROUND_COLOR=#ffffff

VITE_UPLOAD_MAX_SIZE=5242880
VITE_UPLOAD_ACCEPTED_TYPES=image/jpeg,image/png,image/gif,application/pdf

VITE_DEFAULT_PAGE_SIZE=20
VITE_MAX_PAGE_SIZE=100

VITE_ECHARTS_THEME=light
VITE_ECHARTS_RENDERER=canvas

VITE_MOBILE_BREAKPOINT=768
VITE_TABLET_BREAKPOINT=1024