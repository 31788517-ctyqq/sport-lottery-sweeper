# 数据库配置
DATABASE_URL=sqlite:///./sport_lottery.db

# API配置
API_HOST=0.0.0.0
API_PORT=8000

# 爬虫配置
CRAWL_INTERVAL=1800
MAX_CONCURRENT_REQUESTS=5

# 启用自动爬取
AUTO_SCRAPER_ENABLED=True  

# 数据源配置
NETEASE_SPORTS_URL=https://sports.163.com
SINA_SPORTS_URL=https://sports.sina.com.cn
TENCENT_SPORTS_URL=https://sports.qq.com

# 权重配置
INJURY_WEIGHT=9.0
WEATHER_WEIGHT=7.5
REFEREE_WEIGHT=7.0
MOTIVE_WEIGHT=8.5
TACTICS_WEIGHT=7.0
COACH_WEIGHT=7.5
OTHER_WEIGHT=6.0