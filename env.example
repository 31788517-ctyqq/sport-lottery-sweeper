# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USER=soccer_user
DB_PASSWORD=soccer_pass
DB_NAME=soccer_db

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_pass

# MongoDB配置
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=mongo_user
MONGO_PASSWORD=mongo_pass
MONGO_DB=soccer_intelligence

# RabbitMQ配置
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=rabbit_user
RABBITMQ_PASSWORD=rabbit_pass

# 应用配置
SECRET_KEY=your-secret-key-here-change-in-production
ENVIRONMENT=development
DEBUG=true

# API配置
API_V1_STR=/api/v1
API_URL=http://localhost:8000

# 前端配置
VITE_API_URL=http://localhost:8000

# 邮件配置
SMTP_TLS=true
SMTP_PORT=587
SMTP_HOST=smtp.gmail.com
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-password
EMAILS_FROM_EMAIL=your-email@gmail.com
EMAILS_FROM_NAME=Soccer Scanning System

# 文件上传配置
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=5242880

# JWT配置
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# Elasticsearch配置
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200

# Sentry配置
SENTRY_DSN=your-sentry-dsn

# Grafana配置
GRAFANA_PASSWORD=admin

# 监控配置
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001


## 9. 补充：`.env.example` - 环境变量示例
```bash
# ============================================
# 竞彩足球扫盘系统 - 环境变量配置
# ============================================

# 应用配置
APP_NAME="竞彩足球扫盘系统"
DEBUG=false
ENVIRONMENT="production"
SECRET_KEY="your-secret-key-change-in-production-and-make-it-very-long"

# 服务器配置
HOST="0.0.0.0"
PORT=8000

# 数据库配置
DATABASE_URL="postgresql://user:password@localhost:5432/football_scan"
DATABASE_TEST_URL="postgresql://user:password@localhost:5432/football_scan_test"

# Redis配置
REDIS_URL="redis://localhost:6379/0"
REDIS_CACHE_TTL=300

# JWT配置
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS配置
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080","https://football-scan.com"]

# 爬虫配置
CRAWLER_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/119.0.0.0 Safari/537.36"
CRAWLER_REQUEST_DELAY=2.0
CRAWLER_MAX_RETRIES=3

# 文件存储
UPLOAD_DIR="uploads"
MAX_UPLOAD_SIZE=10485760  # 10MB

# 日志配置
LOG_LEVEL="INFO"
LOG_FILE="logs/app.log"

# Celery配置
CELERY_BROKER_URL="redis://localhost:6379/1"
CELERY_RESULT_BACKEND="redis://localhost:6379/2"

# 外部API配置
WEATHER_API_KEY="your-weather-api-key"
WEATHER_API_URL="https://api.weatherapi.com/v1/current.json"

# 邮件配置
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
EMAIL_FROM="noreply@football-scan.com"

# 安全配置
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128
RATE_LIMIT_PER_MINUTE=60

# 监控配置
PROMETHEUS_MULTIPROC_DIR="/tmp/prometheus"
SENTRY_DSN="your-sentry-dsn"

# 第三方服务配置
# 竞彩官方API
JC_OFFICIAL_API_KEY="your-jc-api-key"
JC_OFFICIAL_API_SECRET="your-jc-api-secret"

# 博彩公司API
BOOKMAKER_API_KEY="your-bookmaker-api-key"
BOOKMAKER_API_SECRET="your-bookmaker-api-secret"

# 社交媒体API
TWITTER_API_KEY="your-twitter-api-key"
TWITTER_API_SECRET="your-twitter-api-secret"

# 代理服务
PROXY_ENABLED=false
PROXY_URL="http://proxy-server:port"
PROXY_USERNAME="proxy-username"
PROXY_PASSWORD="proxy-password"

# 功能开关
FEATURE_REALTIME_UPDATES=true
FEATURE_AI_PREDICTIONS=true
FEATURE_PDF_EXPORT=true
FEATURE_EMAIL_NOTIFICATIONS=true