锘?template>
  <div class="beidan-filter-panel">
    <el-card class="filter-card">
      <template #header>
        <div class="card-header">
          <div class="header-title">
            <div class="title">娑撳娣划鍓х暬缁涙盯鈧娅?/div>
            <div class="subtitle">閸╄桨绨?铻朠 / 铻朩P / P-Tier 閻ㄥ嫯浠堥崝銊х摣闁?/div>
          </div>
          <div class="header-actions">
            <div class="match-count">鐎圭偞妞傞崠褰掑帳 <span>{{ totalResults }}</span> 閸?/div>
            <el-button type="primary" @click="fetchRealData" :loading="loading">閼惧嘲褰囩€圭偞妞傞弫鐗堝祦</el-button>
          </div>
        </div>
      </template>

      <!-- 缁涙盯鈧娼禒璺哄隘閸?-->
      <div class="filter-section">
        <el-row :gutter="20" class="dimension-row">
          <el-col :span="8">
            <div class="filter-group">
              <div class="group-title">
                <span>鐎圭偛濮忕粵澶岄獓瀹?铻朠</span>
                <span class="group-hint">娑撹顓圭€圭偛濮忓顔煎瀻鐏?/span>
              </div>
              <el-checkbox-group v-model="filterForm.powerDiffs" class="checkbox-grid">
                <el-checkbox-button
                  v-for="option in strengthOptions"
                  :key="option.value"
                  :value="option.value"
                >
                  <div class="option-tile">
                    <div class="option-value">{{ option.label }}</div>
                    <div class="option-desc">{{ option.desc }}</div>
                    <div class="option-range">{{ option.range }}</div>
                  </div>
                </el-checkbox-button>
              </el-checkbox-group>
            </div>
          </el-col>

          <el-col :span="8">
            <div class="filter-group">
              <div class="group-title">
                <span>鐠с垻娲忕粵澶岄獓瀹?铻朩P</span>
                <span class="group-hint">閻╂鐭鹃崗鎴犲箛閸旀稑顕幘?/span>
              </div>
              <el-checkbox-group v-model="filterForm.winPanDiffs" class="checkbox-grid">
                <el-checkbox-button
                  v-for="option in winPanOptions"
                  :key="option.value"
                  :value="option.value"
                >
                  <div class="option-tile">
                    <div class="option-value">{{ option.label }}</div>
                    <div class="option-desc">{{ option.desc }}</div>
                    <div class="option-range">{{ option.range }}</div>
                  </div>
                </el-checkbox-button>
              </el-checkbox-group>
            </div>
          </el-col>

          <el-col :span="8">
            <div class="filter-group">
              <div class="group-title">
                <span>娑撯偓鐠ф梻菙鐎规碍鈧?P-Tier</span>
                <span class="group-hint">濮濓綀鐭鹃崣顖欎繆鎼达妇鐡戠痪?/span>
              </div>
              <el-checkbox-group v-model="filterForm.stabilityTiers" class="tier-grid">
                <el-checkbox-button
                  v-for="option in stabilityOptions"
                  :key="option.value"
                  :value="option.value"
                >
                  <div class="tier-tile">
                    <div class="tier-label">{{ option.label }}</div>
                    <div class="tier-desc">{{ option.desc }}</div>
                    <div class="tier-range">{{ option.range }}</div>
                  </div>
                </el-checkbox-button>
              </el-checkbox-group>
            </div>
          </el-col>
        </el-row>

        <el-row :gutter="20" class="control-row">
          <el-col :span="8">
            <div class="filter-group">
              <div class="group-title">
                <span>妤傛楠囩粵娑⑩偓?/span>
                <span class="group-hint">婢舵氨娣崣鐘插</span>
              </div>
              <div class="filter-item">
                <label>閼辨棁绂岀粵娑⑩偓?/label>
                <el-select
                  v-model="filterForm.leagues"
                  placeholder="鐠囩兘鈧瀚ㄩ懕鏃囩"
                  multiple
                  collapse-tags
                  style="width: 100%"
                >
                  <el-option
                    v-for="league in availableLeagues"
                    :key="league"
                    :label="league"
                    :value="league"
                  />
                </el-select>
              </div>
              <div class="filter-item">
                <label>date_time</label>
                <el-select
                  v-model="filterForm.dateTime"
                  placeholder="date_time"
                  clearable
                  style="width: 100%"
                >
                  <el-option
                    v-for="value in dateTimeOptions"
                    :key="value"
                    :label="value"
                    :value="value"
                  />
                </el-select>
              </div>
              <div class="filter-item">
                <label>閺冦儲婀￠懠鍐ㄦ纯</label>
                <el-date-picker
                  v-model="filterForm.dateRange"
                  type="daterange"
                  range-separator="閼?
                  start-placeholder="瀵偓婵妫╅張?
                  end-placeholder="缂佹挻娼弮銉︽埂"
                  style="width: 100%"
                />
              </div>
            </div>
          </el-col>

          <el-col :span="8">
            <div class="filter-group">
              <div class="group-title">
                <span>缁涙盯鈧鐡ラ悾?/span>
                <span class="group-hint">閹烘帒绨稉搴ゎ潐閸?/span>
              </div>
              <div class="filter-item">
                <label>閹烘帒绨弬鐟扮础</label>
                <el-radio-group v-model="filterForm.sortBy">
                  <el-radio label="p_level">P缁?/el-radio>
                  <el-radio label="delta_wp">铻朩P</el-radio>
                  <el-radio label="power_diff">铻朠</el-radio>
                </el-radio-group>
              </div>
              <div class="filter-item">
                <label>閹烘帒绨い鍝勭碍</label>
                <el-radio-group v-model="filterForm.sortOrder">
                  <el-radio label="asc">閸楀洤绨?/el-radio>
                  <el-radio label="desc">闂勫秴绨?/el-radio>
                </el-radio-group>
              </div>
              <div class="filter-item switch-item">
                <label>鎼存梻鏁ら梽宥囬獓鐟欏嫬鍨?/label>
                <el-switch v-model="filterForm.includeDerating" />
              </div>
              <div class="rule-preview">閹烘帒绨０鍕潔閿涙瓍缁狙囨鎼?閳?铻朩P闂勫秴绨?/div>
            </div>
          </el-col>

          <el-col :span="8">
            <div class="filter-group">
              <div class="group-title">
                <span>韫囶偅宓庣紒鍕値</span>
                <span class="group-hint">娑撯偓闁款喖绨查悽?/span>
              </div>
              <div class="preset-grid">
                <el-button @click="applyPreset('strong')">瀵搫濞嶅锝堢熅</el-button>
                <el-button @click="applyPreset('upset')">閸愮兘妫婊嗗窛</el-button>
                <el-button @click="applyPreset('balance')">閸у洩銆€閸楁艾绱?/el-button>
              </div>

              <el-alert
                v-if="directionWarning"
                title="閺傜懓鎮滈懗宀€顬囨０鍕劅閿涙艾鐤勯崝娑楃瑢閻╂鐭鹃柅澶嬪閺傜懓鎮滈惄绋垮冀閿涘苯褰查懗鍊熜曢崣鎴︽缁?
                type="warning"
                :closable="false"
                class="direction-alert"
              />

              <div class="filter-actions">
                <el-button type="primary" @click="applyAdvancedFilter" :loading="loading">鎼存梻鏁ょ粵娑⑩偓?/el-button>
                <el-button @click="resetFilters">闁插秶鐤?/el-button>
                <el-dropdown @command="handleSaveStrategy">
                  <el-button type="success">
                    娣囨繂鐡ㄧ粵鏍殣<i class="el-icon-arrow-down el-icon--right"></i>
                  </el-button>
                  <template #dropdown>
                    <el-dropdown-menu>
                      <el-dropdown-item command="save">娣囨繂鐡ㄨぐ鎾冲缁涙牜鏆?/el-dropdown-item>
                      <el-dropdown-item command="load">閸旂姾娴囩粵鏍殣</el-dropdown-item>
                    </el-dropdown-menu>
                  </template>
                </el-dropdown>
              </div>
            </div>
          </el-col>
        </el-row>
      </div>
    </el-card>

    <!-- 缂佺喕顓告穱鈩冧紖閸栧搫鐓?-->
    
    
    
    
    <el-card class="strategy-card">
      <div class="strategy-bar">
        <div class="strategy-select">
          <span class="strategy-label">缁涙牜鏆愮粵娑⑩偓?/span>
          <el-select
            v-model="selectedStrategyName"
            placeholder="闁瀚ㄥ韫箽鐎涙娈戠粵鏍殣"
            clearable
            filterable
            style="width: 260px"
            @change="handleSelectStrategy"
          >
            <el-option
              v-for="name in strategyOptions"
              :key="name"
              :label="name"
              :value="name"
            />
          </el-select>
          <el-button size="small" @click="loadStrategyOptions">閸掗攱鏌?/el-button>
        </div>
        <div class="strategy-detail" v-if="strategyDetailItems.length">
          <div class="detail-item" v-for="item in strategyDetailItems" :key="item.label">
            <span class="detail-label">{{ item.label }}:</span>
            <span class="detail-value">{{ item.value }}</span>
          </div>
        </div>
        <div class="strategy-empty" v-else>
          闁瀚ㄧ粵鏍殣閸氬骸鐨㈤弰鍓с仛鐠囷附鍎?
        </div>
      </div>
      <div class="strategy-list" v-if="strategyOptions.length">
        <div class="strategy-list-title">缁涙牜鏆愰崚妤勩€?/div>
        <div class="strategy-grid">
          <div
            class="strategy-item"
            v-for="name in strategyOptions"
            :key="name"
            :class="{ active: name === selectedStrategyName }"
            @click="handleSelectStrategy(name)"
          >
            <div class="strategy-item-header">
              <span class="strategy-item-name">{{ name }}</span>
              <span class="strategy-item-tag" v-if="name === selectedStrategyName">瀹告煡鈧?/span>
            </div>          </div>
        </div>
      </div>
      <div class="strategy-list-empty" v-else>
        閺嗗倹妫ゅ韫箽鐎涙鐡ラ悾?
      </div>
    </el-card>




    <el-card class="stats-card" v-if="showStats && strategyApplied">
      <template #header>
        <div class="card-header">
          <span>缁涙盯鈧绮虹拋?/span>
        </div>
      </template>

      <el-row :gutter="20">
        <el-col :span="6">
          <div class="stat-item">
            <div class="stat-number">{{ statistics.total_matches }}</div>
            <div class="stat-label">缁楋箑鎮庨弶鈥叉閸︾儤顐?/div>
          </div>
        </el-col>

        <el-col :span="6">
          <div class="stat-item">
            <div class="stat-number">{{ filterForm.powerDiffs.length > 0 ? statistics.delta_p_count || 0 : '閺堫亣顔曠純? }}</div>
            <div class="stat-label">鐎圭偛濮忕粵澶岄獓瀹?铻朠</div>
          </div>
        </el-col>

        <el-col :span="6">
          <div class="stat-item">
            <div class="stat-number">{{ filterForm.winPanDiffs.length > 0 ? statistics.delta_wp_count || 0 : '閺堫亣顔曠純? }}</div>
            <div class="stat-label">鐠с垻娲忕粵澶岄獓瀹?铻朩P</div>
          </div>
        </el-col>

        <el-col :span="6">
          <div class="stat-item">
            <div class="stat-number">{{ filterForm.stabilityTiers.length > 0 ? statistics.p_tier_count || 0 : '閺堫亣顔曠純? }}</div>
            <div class="stat-label">娑撯偓鐠ф梻菙鐎规碍鈧?P-Tier</div>
          </div>
        </el-col>
      </el-row>
    </el-card>

    <!-- 缂佹挻鐏夌仦鏇犮仛閸栧搫鐓?-->
    <el-card class="result-card" v-if="strategyApplied">
      <template #header>
        <div class="card-header">
          <span>缁涙盯鈧绮ㄩ弸?/span>
          <div>
            <el-button @click="exportResults('excel')">鐎电厧鍤璄xcel</el-button>
            <el-button @click="exportResults('csv')">鐎电厧鍤瑿SV</el-button>
            <el-button @click="toggleStats">{{ showStats ? '闂呮劘妫岀紒鐔活吀' : '閺勫墽銇氱紒鐔活吀' }}</el-button>
          </div>
        </div>
      </template>

      <el-table
        :data="pagedResults"
        style="width: 100%"
        v-loading="loading"
        @sort-change="handleSortChange"
      >
        <el-table-column prop="match_id" label="濮ｆ棁绂孖D" width="120" sortable>
          <template #default="{ row }">{{ formatMatchId(row.match_id) }}</template>
        </el-table-column>
        <el-table-column prop="home_team" label="娑撳妲? width="120">
          <template #default="{ row }">{{ displayValue(row.home_team) }}</template>
        </el-table-column>
        <el-table-column prop="away_team" label="鐎广垽妲? width="120">
          <template #default="{ row }">{{ displayValue(row.away_team) }}</template>
        </el-table-column>
        <el-table-column prop="league" label="閼辨棁绂? width="120">
          <template #default="{ row }">{{ displayValue(row.league) }}</template>
        </el-table-column>
        <el-table-column prop="match_time" label="濮ｆ棁绂岄弮鍫曟？" width="170">
          <template #default="{ row }">{{ formatMatchTime(row.match_time) }}</template>
        </el-table-column>
        <el-table-column prop="power_diff" label="铻朠" width="80" sortable>
          <template #default="{ row }">{{ displayValue(row.power_diff) }}</template>
        </el-table-column>
        <el-table-column prop="delta_wp" label="铻朩P" width="100" sortable>
          <template #default="{ row }">{{ displayValue(row.delta_wp) }}</template>
        </el-table-column>
        <el-table-column prop="p_level" label="P缁? width="80" sortable>
          <template #default="{ row }">
            <el-tag v-if="row.p_level" :type="getPLevelTagType(row.p_level)">P{{ row.p_level }}</el-tag>
            <span v-else>-</span>
          </template>
        </el-table-column>
        <el-table-column prop="power_home" label="娑撳妲︾€圭偛濮? width="100" sortable>
          <template #default="{ row }">{{ displayValue(row.power_home) }}</template>
        </el-table-column>
        <el-table-column prop="power_away" label="鐎广垽妲︾€圭偛濮? width="100" sortable>
          <template #default="{ row }">{{ displayValue(row.power_away) }}</template>
        </el-table-column>
        <el-table-column prop="win_pan_home" label="娑撳妲︾挧銏㈡磸" width="100" sortable>
          <template #default="{ row }">{{ displayValue(row.win_pan_home) }}</template>
        </el-table-column>
        <el-table-column prop="win_pan_away" label="鐎广垽妲︾挧銏㈡磸" width="100" sortable>
          <template #default="{ row }">{{ displayValue(row.win_pan_away) }}</template>
        </el-table-column>
        <el-table-column prop="home_feature" label="娑撳妲﹂悧鐟扮窙" width="120">
          <template #default="{ row }">{{ displayValue(row.home_feature) }}</template>
        </el-table-column>
        <el-table-column prop="away_feature" label="鐎广垽妲﹂悧鐟扮窙" width="120">
          <template #default="{ row }">{{ displayValue(row.away_feature) }}</template>
        </el-table-column>
        <el-table-column label="閹垮秳缍? width="150">
          <template #default="{ row }">
            <el-button size="small" type="success" @click="openAnalysis(row)">閸掑棙鐎?/el-button>
          </template>
        </el-table-column>
      </el-table>






      
      <el-pagination
        @size-change="handleSizeChange"
        @current-change="handleCurrentChange"
        :current-page="currentPage"
        :page-sizes="[10, 20, 50, 100]"
        :page-size="pageSize"
        :total="totalResults"
        layout="slot, sizes, prev, pager, next, jumper"
        prev-text="娑撳﹣绔存い?
        next-text="娑撳绔存い?
        style="margin-top: 20px; text-align: right;"
      >
        <span class="pagination-total">閸?{{ totalResults }} 閺?/span>
      </el-pagination>

    </el-card>
    
    <!-- P缁狙嗩潐閸掓瑨顕╅弰搴¤剨缁?-->
    <el-dialog title="P缁狙嗩吀缁犳顫夐崚? v-model="showRulesDialog" width="60%">
      <div v-if="pLevelRules">
        <h3>鐠囧嫮楠囬弽鍥у櫙</h3>
        <ul>
          <li><strong>P1閿?/strong>{{ pLevelRules.p1_criteria }}</li>
          <li><strong>P2閿?/strong>{{ pLevelRules.p2_criteria }}</li>
          <li><strong>P3閿?/strong>{{ pLevelRules.p3_criteria }}</li>
          <li><strong>P4閿?/strong>{{ pLevelRules.p4_criteria }}</li>
          <li><strong>P5閿?/strong>{{ pLevelRules.p5_criteria }}</li>
        </ul>
        
        <h3>闂勫秶楠囩憴鍕灟</h3>
        <ol>
          <li v-for="(rule, index) in pLevelRules.derating_rules" :key="index">{{ rule }}</li>
        </ol>
        
        <h3>閹烘帒绨憴鍕灟</h3>
        <ol>
          <li v-for="(rule, index) in pLevelRules.sort_rules" :key="'sort'+index">{{ rule }}</li>
        </ol>
      </div>
    </el-dialog>

    <el-dialog title="濮ｆ棁绂岄崚鍡樼€? v-model="showAnalysisDialog" width="70%" class="analysis-dialog">
      <div v-if="analysisData">
        <div class="analysis-sim-container">
          <div class="analysis-sim-header">
            <div class="analysis-sim-title">濮ｆ棁绂岄崚鍡樼€藉Ο鈩冨珯</div>
            <div class="analysis-sim-subtitle">閸╄桨绨?00閻炲啯鏆熼幑顔炬畱濮ｆ棁绂岄崚鍡樼€界仦鏇犮仛</div>
          </div>

          <div class="analysis-sim-card">
            <div class="analysis-sim-card-title">濮ｆ棁绂岄崺鐑樻拱娣団剝浼?/div>
            <div class="analysis-sim-basic">
              <div class="analysis-sim-team">
                <div class="analysis-sim-team-name">{{ analysisData.homeTeam || '-' }}</div>
                <div class="analysis-sim-team-meta">鐎圭偛濮忛崐? {{ analysisData.homePower ?? '-' }}</div>
              </div>
              <div class="analysis-sim-vs">
                <div class="analysis-sim-league">{{ analysisData.gameShortName || '-' }}</div>
                <div class="analysis-sim-vs-text">VS</div>
                <div class="analysis-sim-time">{{ analysisData.matchTimeStr || '-' }}</div>
              </div>
              <div class="analysis-sim-team">
                <div class="analysis-sim-team-name">{{ analysisData.guestTeam || '-' }}</div>
                <div class="analysis-sim-team-meta">鐎圭偛濮忛崐? {{ analysisData.guestPower ?? '-' }}</div>
              </div>
            </div>
            <div class="analysis-sim-odds">
              <div class="analysis-sim-odds-item"><span>娑撴槒鍎?/span><strong>{{ analysisData.homeWinAward ?? '-' }}</strong></div>
              <div class="analysis-sim-odds-item"><span>楠炲啿鐪?/span><strong>{{ analysisData.drawAward ?? '-' }}</strong></div>
              <div class="analysis-sim-odds-item"><span>鐎广垼鍎?/span><strong>{{ analysisData.guestWinAward ?? '-' }}</strong></div>
              <div class="analysis-sim-odds-item"><span>鐠佲晝鎮?/span><strong>{{ analysisData.rq ?? '-' }}</strong></div>
            </div>
          </div>

          <div class="analysis-sim-card">
            <div class="analysis-sim-card-title">閻炲啴妲︾€圭偛濮忕€佃鐦?/div>
            <div class="analysis-sim-progress">
              <div class="analysis-sim-progress-labels">
                <span>{{ analysisData.homeTeam || '-' }}</span>
                <span>{{ analysisData.guestTeam || '-' }}</span>
              </div>
              <div class="analysis-sim-progress-bars">
                <el-progress :percentage="getProgressValue(analysisData.homePower)" :show-text="false" :color="'#a4b2a4'" />
                <el-progress :percentage="getProgressValue(analysisData.guestPower)" :show-text="false" :color="'#b9a7a0'" />
              </div>
            </div>
            <div class="analysis-sim-table">
              <div class="analysis-sim-table-row analysis-sim-table-head">
                <span>閹稿洦鐖?/span><span>娑撳妲?/span><span>鐎广垽妲?/span><span>娴兼ê濞嶉弬?/span>
              </div>
              <div class="analysis-sim-table-row">
                <span>缁夘垰鍨庨敍鍫滃瘜閸?閹紮绱?/span>
                <span>{{ analysisData.homeJiFenHome || '-' }}/{{ analysisData.homeJiFenHomeAll || '-' }}</span>
