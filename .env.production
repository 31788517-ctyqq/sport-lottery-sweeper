# =============================================================================
# 体育彩票扫盘系统 - 主配置文件 (开发环境)
# =============================================================================
# 注意：此文件包含开发环境的实际配置值
# 生产环境请使用 .env.production

# =============================================================================
# PROJECT 配置
# =============================================================================
APP_NAME=竞彩足球扫盘系统
APP_VERSION=1.0.0
DESCRIPTION=Sport Lottery Sweeper System API
PROJECT_NAME=竞彩足球扫盘系统
PROJECT_NAME_CN=竞彩足球扫盘系统
VERSION=0.2.0

# =============================================================================
# ENVIRONMENT 配置
# =============================================================================
# 环境类型: development, staging, production
ENVIRONMENT=development
DEBUG=true
NODE_ENV=development

# =============================================================================
# SERVER 配置
# =============================================================================
# 后端服务配置
HOST=0.0.0.0
PORT=8000

# 前端开发服务器配置
VITE_DEV_SERVER_HOST=0.0.0.0
VITE_DEV_SERVER_PORT=3000

# =============================================================================
# API 配置
# =============================================================================
API_URL=http://localhost:8000
API_V1_PREFIX=/api/v1
API_V1_STR=/api/v1
# 前端API基础URL - 开发环境使用空字符串以启用Vite代理
VITE_API_BASE_URL=
VITE_API_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000/ws

# =============================================================================
# DATABASE 配置
# =============================================================================
# 统一数据库文件位置到项目根目录
DATABASE_URL=sqlite:///sport_lottery.db
ASYNC_DATABASE_URL=sqlite+aiosqlite:///sport_lottery.db

# =============================================================================
# REDIS 配置
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# =============================================================================
# SECURITY 配置
# =============================================================================
# JWT配置 - 使用固定的安全密钥
SECRET_KEY=your-very-long-and-secure-secret-key-here-12345678901234567890
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_HASH_ALGORITHM=bcrypt

# CORS配置
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080

# =============================================================================
# FEATURE FLAGS 功能开关
# =============================================================================
ENABLE_INTELLIGENCE_MODULE=true
ENABLE_USER_MANAGEMENT=true
ENABLE_SYSTEM_SETTINGS=true
ENABLE_DATA_EXPORT=true
ENABLE_REAL_TIME_UPDATES=true
ENABLE_DATA_COLLECTION=true
ENABLE_MODEL_MANAGEMENT=true
ENABLE_WEIGHT_MANAGEMENT=true
ENABLE_GRAPH_MANAGEMENT=true
ENABLE_PREDICTION_ENGINE=true
ENABLE_DARK_MODE=true
ENABLE_THEME_SWITCHER=true
ENABLE_ANIMATIONS=true
ENABLE_TOOLTIPS=true
ENABLE_BREADCRUMBS=true

# =============================================================================
# CRAWLER 爬虫配置
# =============================================================================
CRAWLER_CONCURRENT_REQUESTS=5
CRAWLER_DOWNLOAD_DELAY=1
CRAWLER_TIMEOUT=30
CRAWLER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# =============================================================================
# API Keys (开发环境可以使用测试密钥)
# =============================================================================
# AI服务配置
OPENAI_API_KEY=your-openai-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
QWEN_API_KEY=sk-cc3a64c71b9b4696990d2d731b8c7b39

# 体育彩票API配置
SP_API_BASE_URL=https://api.example.com
SP_API_KEY=your-api-key
SP_API_SECRET=your-api-secret

# 第三方服务API
JC_OFFICIAL_API_KEY=your-jc-api-key-here
JC_OFFICIAL_API_SECRET=your-jc-api-secret-here
BOOKMAKER_API_KEY=your-bookmaker-api-key-here
BOOKMAKER_API_SECRET=your-bookmaker-api-secret-here
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
WEATHER_API_KEY=your-weather-api-key-here

# =============================================================================
# SYSTEM 系统配置
# =============================================================================
# 时区和本地化
APP_TIMEZONE=Asia/Shanghai
APP_LOCALE=zh_CN

# 文件上传
MAX_FILE_SIZE=10485760
UPLOAD_FOLDER=uploads/
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,csv,xlsx,json,txt

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10MB
LOG_BACKUP_COUNT=5

# 监控配置
MONITORING_ENABLED=true
HEALTH_CHECK_INTERVAL=30

# 安全配置
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_DURATION=300

# IP池配置
USE_IP_POOL=false
IP_POOL_API_URL=
MIN_IP_COUNT=5
MAX_IP_COUNT=20

# 任务调度
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
TASK_INTERVAL=60

# =============================================================================
# EMAIL 邮件配置
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAILS_FROM_EMAIL=your-email@gmail.com
EMAILS_FROM_NAME=竞彩足球扫盘系统

# =============================================================================
# 关键业务配置
# =============================================================================
# 启用完整API模式 - 确保所有端点可用
FULL_API_MODE=true

# 代理配置（如需要）
HTTP_PROXY=
HTTPS_PROXY=