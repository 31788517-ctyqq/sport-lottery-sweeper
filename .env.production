# =============================================================================
# 体育彩票扫盘系统 - 生产环境配置
# =============================================================================
# 警告：此文件包含生产环境配置，请勿提交到版本控制系统
# 请通过环境变量或安全的配置管理系统设置敏感信息

# =============================================================================
# ENVIRONMENT 配置
# =============================================================================
ENVIRONMENT=production
DEBUG=false
NODE_ENV=production

# =============================================================================
# SERVER 配置
# =============================================================================
HOST=0.0.0.0
PORT=8000
VITE_DEV_SERVER_HOST=0.0.0.0
VITE_DEV_SERVER_PORT=3000

# =============================================================================
# DATABASE 配置 (生产环境建议使用 PostgreSQL)
# =============================================================================
# DATABASE_URL=postgresql://user:password@localhost:5432/sport_lottery_prod
# ASYNC_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/sport_lottery_prod

# 如使用SQLite（不推荐生产环境）
DATABASE_URL=sqlite:///sport_lottery_prod.db
ASYNC_DATABASE_URL=sqlite+aiosqlite:///sport_lottery_prod.db

# =============================================================================
# REDIS 配置
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your-redis-production-password

# =============================================================================
# SECURITY 配置 (必须使用强密钥)
# =============================================================================
SECRET_KEY=CHANGE-THIS-TO-A-VERY-LONG-RANDOM-STRING-64-CHARS-MINIMUM-PRODUCTION-KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_HASH_ALGORITHM=bcrypt

# CORS配置 (限制为实际域名)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# =============================================================================
# API Keys (生产环境真实密钥)
# =============================================================================
OPENAI_API_KEY=your-real-openai-api-key
GEMINI_API_KEY=your-real-gemini-api-key
QWEN_API_KEY=your-real-qwen-api-key

# =============================================================================
# FEATURE FLAGS (生产环境建议关闭调试功能)
# =============================================================================
ENABLE_INTELLIGENCE_MODULE=true
ENABLE_USER_MANAGEMENT=true
ENABLE_SYSTEM_SETTINGS=true
ENABLE_DATA_EXPORT=true
ENABLE_REAL_TIME_UPDATES=true
ENABLE_DATA_COLLECTION=true
ENABLE_MODEL_MANAGEMENT=true
ENABLE_WEIGHT_MANAGEMENT=true
ENABLE_GRAPH_MANAGEMENT=true
ENABLE_PREDICTION_ENGINE=true
ENABLE_DARK_MODE=true
ENABLE_THEME_SWITCHER=false
ENABLE_ANIMATIONS=false
ENABLE_TOOLTIPS=true
ENABLE_BREADCRUMBS=true

# =============================================================================
# SYSTEM 优化配置
# =============================================================================
APP_TIMEZONE=Asia/Shanghai
APP_LOCALE=zh_CN
LOG_LEVEL=WARNING
MONITORING_ENABLED=true
HEALTH_CHECK_INTERVAL=60

# 安全加强
MAX_LOGIN_ATTEMPTS=3
LOGIN_LOCKOUT_DURATION=600

# =============================================================================
# 生产环境特定配置
# =============================================================================
FULL_API_MODE=true
USE_IP_POOL=true
MAX_CONCURRENT_SCRAPERS=10