# 后端测试环境配置示例
# 复制此文件为 .env.test 并修改相应值

# 数据库配置（测试环境使用SQLite）
DATABASE_URL=sqlite:///./test.db

# Redis配置
REDIS_URL=redis://localhost:6379/0

# 安全密钥（仅用于测试）
SECRET_KEY=test-secret-key-for-local-testing
JWT_SECRET_KEY=test-jwt-secret-key-for-local-testing

# 应用环境
ENVIRONMENT=testing
DEBUG=true

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=test.log

# 测试配置
TEST_DATABASE_URL=sqlite:///./test.db
TEST_REDIS_URL=redis://localhost:6379/0
TEST_MODE=true

# 爬虫测试配置
TEST_CRAWLER_ENABLED=false
TEST_PROXY_ENABLED=false

# API测试配置
TEST_API_TIMEOUT=30
TEST_MAX_RETRIES=3

# 邮件测试配置（使用本地邮件服务器）
TEST_EMAIL_HOST=localhost
TEST_EMAIL_PORT=1025
TEST_EMAIL_USE_TLS=false
TEST_EMAIL_USERNAME=
TEST_EMAIL_PASSWORD=

# 文件上传测试配置
TEST_UPLOAD_DIR=./test_uploads
TEST_MAX_UPLOAD_SIZE=10485760  # 10MB