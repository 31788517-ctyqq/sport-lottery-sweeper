# ====================================
# 竞彩足球扫盘系统开发环境 Dockerfile
# ====================================

# 阶段1: 构建基础镜像
FROM python:3.11-alpine AS base
LABEL maintainer="soccer-scanning-system"
LABEL version="1.0.0"

# 设置环境变量
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    NODE_VERSION=18 \
    PNPM_HOME="/pnpm" \
    PATH="$PNPM_HOME:$PATH"

# 更新包索引并安装系统依赖
RUN apk update && \
    apk add --no-cache \
        # 基础工具
        git \
        vim \
        curl \
        wget \
        bash \
        make \
        # Python依赖
        gcc \
        musl-dev \
        linux-headers \
        python3-dev \
        # Node.js依赖
        libstdc++ \
        # 其他依赖
        tzdata \
        ca-certificates \
        && rm -rf /var/cache/apk/*

# 安装pnpm
RUN npm install -g pnpm@latest

# 创建应用用户
RUN addgroup -g 1000 appgroup && \
    adduser -D -s /bin/sh -u 1000 -G appgroup appuser

# 阶段2: 安装后端依赖
FROM base AS backend
WORKDIR /app/backend

# 复制后端依赖文件
COPY backend/requirements.txt .

# 升级pip并安装后端依赖
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir --no-dependencies -r requirements.txt

# 阶段3: 安装前端依赖
# 第 58 行（正确）
FROM node:18-alpine AS frontend
WORKDIR /app/frontend

# 使用阿里云镜像的 Python 基础镜像
FROM python:3.11-alpine AS base

# 设置阿里云镜像源
RUN echo "https://mirrors.aliyun.com/alpine/v3.19/main" > /etc/apk/repositories && \
    echo "https://mirrors.aliyun.com/alpine/v3.19/community" >> /etc/apk/repositories

# 设置 pip 镜像源
RUN pip config set global.index-url https://mirrors.aliyun.com/pypi/simple/ && \
    pip config set global.trusted-host mirrors.aliyun.com

LABEL maintainer="soccer-scanning-system"
LABEL version="1.0.0"
# 配置npm镜像
RUN npm config set registry https://registry.npmmirror.com/

# 复制前端依赖文件
COPY frontend/package.json ./
COPY frontend/pnpm-lock.yaml ./

# 安装pnpm并安装依赖
RUN npm install -g pnpm@latest && \
    pnpm config set store-dir /pnpm/store && \
    pnpm install --frozen-lockfile

# 阶段4: 构建前端
FROM frontend AS builder
WORKDIR /app/frontend

# 复制源代码
COPY frontend/ .

# 构建前端应用
RUN pnpm run build

# 阶段5: 构建开发环境
FROM base AS development

# 安装后端依赖
COPY --from=backend /usr/local/lib/python3.11/site-packages/ /usr/local/lib/python3.11/site-packages/
COPY --from=backend /usr/local/bin/ /usr/local/bin/

# 安装前端依赖
COPY --from=frontend /pnpm/store /pnpm/store
COPY --from=frontend /usr/local/bin/node /usr/local/bin/
COPY --from=frontend /usr/local/bin/npm /usr/local/bin/
COPY --from=frontend /usr/local/bin/pnpm /usr/local/bin/

# 设置工作目录
WORKDIR /app

# 复制应用代码
COPY backend/ backend/
COPY frontend/ frontend/
COPY scripts/ scripts/
COPY config/ config/

# 创建必要的目录
RUN mkdir -p logs data/{postgres,redis,rabbitmq,mongodb,elasticsearch} uploads

# 设置环境变量
ENV NODE_ENV=development \
    VITE_APP_TITLE=竞彩足球扫盘系统 \
    VITE_API_BASE_URL=http://localhost:8000 \
    PYTHONPATH=/app/backend

# 设置目录权限
RUN chown -R appuser:appgroup /app

# 切换到应用用户
USER appuser

# 暴露端口
EXPOSE 3000 8000

# 健康检查
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

# 开发环境启动命令
CMD ["./scripts/start-dev-simple.sh"]